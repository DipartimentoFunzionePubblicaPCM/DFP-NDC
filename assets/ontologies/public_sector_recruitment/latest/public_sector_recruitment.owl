        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/haTipoRuoloInCorso"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/avvisoEsameFinale"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/numeroOreFormazione"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Esperienza formativa a cui un canditato ha preso parte.</rdfs:comment>
        <rdfs:label xml:lang="it">Esperienza di formazione</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/EsperienzaGenerica -->

    <owl:Class rdf:about="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/EsperienzaGenerica">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/TI/TimeIndexedEvent"/>
        <rdfs:comment xml:lang="it">Esperienza professionale non specifica ma che può rilevare per il profilo del partecipante.</rdfs:comment>
        <rdfs:label xml:lang="it">Esperienza generica</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/EsperienzaLavorativa -->

    <owl:Class rdf:about="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/EsperienzaLavorativa">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/TI/TimeIndexedEvent"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/haDatoreDiLavoro"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/haTipoDiContratto"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/haTipoOrarioDiLavoro"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Esperienza professionale di un partecipante che può essere considerata significativa nel processo di selezione.</rdfs:comment>
        <rdfs:label xml:lang="it">Esperienza lavorativa</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/EsperienzaLavorativaPA -->

    <owl:Class rdf:about="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/EsperienzaLavorativaPA">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/EsperienzaLavorativa"/>
        <owl:disjointWith rdf:resource="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/EsperienzaLavorativaPrivata"/>
        <rdfs:comment xml:lang="it">Esperienza professionale maturata all&apos;interno della Pubblica Amministrazione.</rdfs:comment>
        <rdfs:label xml:lang="it">Esperienza lavorativa PA</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/EsperienzaLavorativaPrivata -->

    <owl:Class rdf:about="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/EsperienzaLavorativaPrivata">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/EsperienzaLavorativa"/>
        <rdfs:comment xml:lang="it">Esperienza professionale maturata in aziende private.</rdfs:comment>
        <rdfs:label xml:lang="it">Esperienza lavorativa privata</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/EventoDiFormazione -->

    <owl:Class rdf:about="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/EventoDiFormazione">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/EsperienzaGenerica"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/haEventoDiFormazione"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Evento formativo a cui un partecipante ha preso parte e che può contribuire alla valutazione nel processo di selezione.</rdfs:comment>
        <rdfs:label xml:lang="it">Evento di formazione</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/GradoDiCompetenzaLingua -->

    <owl:Class rdf:about="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/GradoDiCompetenzaLingua">
        <rdfs:comment xml:lang="it">Classifica le competenza nell&apos;utilizzo di una lingua nell&apos;ambito dei diversi usi della stessa (comprensione, parlato, scritto, …) secondo lo standard internazionale.</rdfs:comment>
        <rdfs:label xml:lang="it">Grado di competenza lingua</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/GraduatoriaDiReclutamento -->

    <owl:Class rdf:about="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/GraduatoriaDiReclutamento">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/èGraduatoriaDiProceduraDiReclutamento"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/dataCreazioneGraduatoria"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/titoloGraduatoria"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Istanza della classifica dei candidati in base ai risultati ottenuti nel processo di selezione.</rdfs:comment>
        <rdfs:label xml:lang="it">Graduatoria di reclutamento</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/InformazioneAggiuntiva -->

    <owl:Class rdf:about="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/InformazioneAggiuntiva">
        <rdfs:subClassOf>
