  <rdf:Description rdf:about="https://w3id.org/italia/public-administration-governance/data/public-sector-recruitment/distribution/PARECRUIT-RDF-XML">
    <dcterms:title xml:lang="en">RDF/XML distribution of the inPA Recruitment Portal Ontology</dcterms:title>
    <dcterms:title xml:lang="it">Distribuzione RDF/XML dell'ontologia del Dipartimento della Funzione Pubblica</dcterms:title>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.w3.org/ns/dcat#Distribution"/>
    <rdf:type rdf:resource="http://dati.gov.it/onto/dcatapit#Distribution"/>
