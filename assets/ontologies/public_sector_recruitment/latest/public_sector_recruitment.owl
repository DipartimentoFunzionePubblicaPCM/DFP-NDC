        <rdfs:comment xml:lang="it">Zona territoriale di assegnazione a cui saranno destinati i vincitori della procedura selettiva.</rdfs:comment>
        <rdfs:label xml:lang="it">Area geografica</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/AttivitàDiInsegnamento -->

    <owl:Class rdf:about="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/AttivitàDiInsegnamento">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/haEsperienzaDiInsegnamento"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/haIstitutodiInsegnamento"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/numeroAnniInsegnamento"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/numeroOreInsegnamento"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Incarico formativo svolto da un utente che può essere considerato nel processo di selezione.</rdfs:comment>
        <rdfs:label xml:lang="it">Attività di insegnamento</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/AttoDiEquiparazioneQualificaEstera -->

    <owl:Class rdf:about="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/AttoDiEquiparazioneQualificaEstera">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/AttoDiEquipollenzaQualifica"/>
                    <rdf:Description rdf:about="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/AttoDiEquivalenzaQualifica"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/haAutoritàDiEmissione"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Atto di riconoscimento di una qualifica accademica o professionale conseguita presso una stato estero necessaria per poter svolgere la relativa attività professionale in Italia o partecipare a concorsi indetti dalla PA.</rdfs:comment>
        <rdfs:label xml:lang="it">Atto di equiparazione qualifica estera</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/AttoDiEquipollenzaQualifica -->

    <owl:Class rdf:about="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/AttoDiEquipollenzaQualifica">
        <owl:disjointWith rdf:resource="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/AttoDiEquivalenzaQualifica"/>
        <rdfs:comment xml:lang="it">Sottoclasse di Atto di equiparazione qualifica accademica riferita al riconoscimento accademico del titolo posseduto ovvero all&apos;equiparazione del suo valore legale.</rdfs:comment>
