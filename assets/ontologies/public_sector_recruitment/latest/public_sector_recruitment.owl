        <owl:disjointWith rdf:resource="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/PreferenzaAggiuntiva"/>
        <rdfs:comment xml:lang="it">Dettagli supplementari forniti dal candidato che possono rilevare nel punteggio attribuito alla candidatura.</rdfs:comment>
        <rdfs:label xml:lang="it">Informazione aggiuntiva</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/IntervalloSalariale -->

    <owl:Class rdf:about="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/IntervalloSalariale">
        <rdfs:comment xml:lang="it">Intervallo economico dello stipendio previsto per la posizione oggetto del reclutamento.</rdfs:comment>
        <rdfs:label xml:lang="it">Intervallo salariale</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/IstitutoDiFormazione -->

    <owl:Class rdf:about="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/IstitutoDiFormazione">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/COV/Organization"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/CLV/hasAddress"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/haTipoDiIstitutoDiFormazione"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Classifica gli istituti di formazione nell&apos;ambito del rilascio di una qualifica accademica. È sottoclasse di COV:Organization.</rdfs:comment>
        <rdfs:label xml:lang="it">Istituto di formazione</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/LivelloDiPubblicazione -->

    <owl:Class rdf:about="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/LivelloDiPubblicazione">
        <rdfs:comment xml:lang="it">Classifica la platea e il grado di diffusione della pubblicazione.</rdfs:comment>
        <rdfs:label xml:lang="it">Livello di pubblicazione</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/ModalitàDiValutazione -->

    <owl:Class rdf:about="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/ModalitàDiValutazione">
        <rdfs:comment xml:lang="it">Classificazione dei criteri e metodi utilizzati per valutare i candidati durante il processo di selezione.</rdfs:comment>
        <rdfs:label xml:lang="it">Modalità di valutazione</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/PartecipanteSessioneEsame -->

    <owl:Class rdf:about="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/PartecipanteSessioneEsame">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/haEsitoPartecipazioneSessioneDiEsame"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/onto/RO/holdsRoleInTime"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/haCandidato"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
                    </owl:Restriction>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/haPartecipanteSessioneDiEsame"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/PosizioneInGraduatoriaDiReclutamento"/>
        <rdfs:comment xml:lang="it">Ruolo assunto da un candidato al momento dell&apos;effettiva partecipazione alla selezione per la procedura di reclutamento per cui ha presentato la candidatura.</rdfs:comment>
        <rdfs:label xml:lang="it">Partecipante sessione esame</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/PatenteDiGuida -->

