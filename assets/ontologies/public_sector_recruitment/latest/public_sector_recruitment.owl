            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/haPeriodoDiValiditàPatenteDiGuida"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Classifica la sequenza dei periodi di validità di una patente di guida.</rdfs:comment>
        <rdfs:label xml:lang="it">Periodo di validità patente di guida</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/PosizioneInGraduatoriaDiReclutamento -->

    <owl:Class rdf:about="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/PosizioneInGraduatoriaDiReclutamento">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/èPosizioneInGraduatoria"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Posizione di un candidato all&apos;interno della graduatoria della procedura selettiva.</rdfs:comment>
        <rdfs:label xml:lang="it">Posizione in graduatoria di reclutamento</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/PreferenzaAggiuntiva -->

    <owl:Class rdf:about="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/PreferenzaAggiuntiva">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/haProprietàDellaCandidatura"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Opzione che permette a un candidato di esprimere ulteriori dichiarazioni, se richieste nella candidatura.</rdfs:comment>
        <rdfs:label xml:lang="it">Preferenza aggiuntiva</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/PreferenzaAmbito -->

    <owl:Class rdf:about="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/PreferenzaAmbito">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/DescrittoreGenerico"/>
        <rdfs:comment xml:lang="it">Indicazione da parte di un candidato riguardo all&apos;ambito professionale in cui desidera essere assegnato.</rdfs:comment>
        <rdfs:label xml:lang="it">Preferenza ambito</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/PreferenzaLuogoDiLavoro -->

    <owl:Class rdf:about="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/PreferenzaLuogoDiLavoro">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/CLV/AdminUnitComponent"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/CLV/lat"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/CLV/long"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Indicazione della sede di lavoro in cui un candidato preferirebbe essere assegnato.</rdfs:comment>
        <rdfs:label xml:lang="it">Preferenza luogo di lavoro</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/ProcedureStraordinarie -->

    <owl:Class rdf:about="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/ProcedureStraordinarie">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/PubblicazioneDiReclutamentoPA"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/haCategoriaDiReclutamento"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:oneOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/procedureStraordinarie"/>
                        </owl:oneOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Sottoclasse di Pubblicazione di reclutamento PA che raggruppa le pubblicazioni con categoria di reclutamento valorizzata a &quot;procedure straordinarie&quot;.</rdfs:comment>
        <rdfs:label xml:lang="it">Procedure straordinarie</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/ProprietàDellaCandidatura -->

    <owl:Class rdf:about="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/ProprietàDellaCandidatura">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/etichettaDellaProprietà"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/valoreDellaProprietà"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Istanzia una proprietà o caratteristica del candidato che si vuole far rilevare nell&apos;ambito di una candidatura.</rdfs:comment>
        <rdfs:label xml:lang="it">Proprietà della candidatura</rdfs:label>
    </owl:Class>



