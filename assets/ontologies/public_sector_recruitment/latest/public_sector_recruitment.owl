    <dcat:accessURL rdf:resource="https://github.com/DipartimentoFunzionePubblicaPCM/DFP-NDC/tree/main/assets/ontologies/public_sector_recruitment/latest"/>
    <dcterms:description xml:lang="en">This is the distribution in RDF/XML of the inPA Recruitment Portal Ontology describes some of the main concepts of the Recruitment Portal</dcterms:description>
    <dcterms:description xml:lang="it">Questa è la distribuzione RDF/XML dell'ontologia dei processi di reclutamento nel Portale inPA (Portale unico del reclutamento – in Pubblica Amministrazione) del Ministero per la Pubblica Amministrazione ed in particolare del Dipartimento della Funzione Pubblica.</dcterms:description>
    <dcterms:format rdf:resource="http://publications.europa.eu/resource/authority/file-type/RDF_XML"/>
    <dcterms:license rdf:resource="http://creativecommons.org/licenses/by/4.0/"/>
    <dcat:downloadURL rdf:resource="https://raw.githubusercontent.com/DipartimentoFunzionePubblicaPCM/DFP-NDC/tree/main/assets/ontologies/public_sector_recruitment/latest/public_sector_recruitment.owl"/>
  </rdf:Description>
