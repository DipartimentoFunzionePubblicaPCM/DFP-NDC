    <!-- https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/Allegato -->

    <owl:Class rdf:about="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/Allegato">
        <rdfs:comment xml:lang="it">Documento integrativo di una lettera o una pratica per fornire informazioni aggiuntive o completarne il contenuto.</rdfs:comment>
        <rdfs:label xml:lang="it">Allegato</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/AllegatoCandidatura -->

    <owl:Class rdf:about="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/AllegatoCandidatura">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/Allegato"/>
        <rdfs:comment xml:lang="it">Documento che accompagna la candidatura di un partecipante contenente informazioni e documenti richiesti per la procedura selettiva.</rdfs:comment>
        <rdfs:label xml:lang="it">Allegato candidatura</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/AllegatoPubblicazioneReclutamento -->

    <owl:Class rdf:about="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/AllegatoPubblicazioneReclutamento">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/Allegato"/>
        <rdfs:comment xml:lang="it">Documento correlato alla pubblicazione di procedure selettive di reclutamento che fornisce dettagli aggiuntivi riuardanti il concorso.</rdfs:comment>
        <rdfs:label xml:lang="it">Allegato pubblicazione reclutamento</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment/AreaGeografica -->

