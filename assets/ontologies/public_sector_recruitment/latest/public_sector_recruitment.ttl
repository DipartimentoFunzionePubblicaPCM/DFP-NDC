    rdfs:comment "Indica lo status assunto da una candidatura in un periodo temporale (ad esempio: bozza)."@it .

pa-recruit:tipoDescrittoreRuolo a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "tipo descrittore ruolo"@it ;
    rdfs:domain pa-recruit:DescrittoreRuolo ;
    rdfs:range xsd:string ;
    rdfs:comment "Indica l'ambito in cui è svolto il ruolo."@it .

pa-recruit:tipoDiAllegato a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "tipo di allegato"@it ;
    rdfs:domain pa-recruit:Allegato ;
    rdfs:range xsd:string ;
    rdfs:comment "Tipo di allegato: pdf, doc, xml, ..."@it .

pa-recruit:titoloAllegato a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "titolo allegato"@it ;
    rdfs:domain pa-recruit:Allegato ;
    rdfs:range xsd:string ;
    rdfs:comment "Titolo dell'allegato."@it .

pa-recruit:titoloDellaPubblicazione a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "titolo della pubblicazione"@it ;
    rdfs:domain pa-recruit:PubblicazioneAccademica ;
    rdfs:range xsd:string ;
    rdfs:comment "Titolo della pubblicazione accademica."@it .

pa-recruit:titoloDellaStatistica a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "titolo della statistica"@it ;
    rdfs:domain pa-recruit:StatisticaPubblicazioneReclutamentoPA ;
    rdfs:range xsd:string ;
    rdfs:comment "Titolo della sezione di statistiche"@it .

pa-recruit:titoloGraduatoria a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "titolo graduatoria"@it ;
    rdfs:domain pa-recruit:GraduatoriaDiReclutamento ;
    rdfs:range xsd:string ;
    rdfs:comment "Denominazione della graduatoria."@it .

pa-recruit:titoloInGU a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "titolo in GU"@it ;
    rdfs:domain pa-recruit:PubblicazioneDiReclutamentoPA ;
    rdfs:range xsd:string ;
    rdfs:comment "Titolo della pubblicazione in Gazzetta Ufficiale."@it .

pa-recruit:titoloProceduraReclutamento a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "titolo procedura reclutamento"@it ;
    rdfs:domain pa-recruit:PubblicazioneDiReclutamentoPA ;
    rdfs:range xsd:string ;
    rdfs:comment "Titolo della procedura di reclutamento pubblicata."@it .

pa-recruit:totaleDomandeRicevute a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "totale domande ricevute"@it ;
    rdfs:domain pa-recruit:ConsuntivoDiProcedura ;
    rdfs:range xsd:integer ;
    rdfs:comment "Totale delle domande di partecipazione ricevute."@it .

pa-recruit:totalePagamentiIncassati a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "totale pagamenti incassati"@it ;
    rdfs:domain pa-recruit:ConsuntivoDiProcedura ;
    rdfs:range xsd:float ;
    rdfs:comment "Importo totale dei pagamenti incassati dai partecipanti iscritti alla procedura di reclutamento."@it .

pa-recruit:valoreDellaProprietà a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "valore della proprietà"@it ;
    rdfs:domain pa-recruit:ProprietàDellaCandidatura ;
    rdfs:range xsd:string ;
    rdfs:comment "È il valore della proprietà."@it .

pa-recruit:valoreDelRequisitoPerCandidatura a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "valore del requisito per candidatura"@it ;
    rdfs:domain pa-recruit:ValorizzazioneRequisito ;
    rdfs:range xsd:string ;
    rdfs:comment "È il valore assegnato ad uno specifico requisito nell'ambito di una candidatura."@it .

pa-recruit:valoreElementoStatistico a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "valore elemento statistico"@it ;
    rdfs:domain pa-recruit:ElementoStatistico ;
    rdfs:range xsd:float ;
    rdfs:comment "Valore numerico dell'elemento statistico."@it .

pa-recruit:valoreElementoStatisticoTestuale a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "valore elemento statistico testuale"@it ;
    rdfs:domain pa-recruit:ElementoStatistico ;
    rdfs:range xsd:string ;
    rdfs:comment "Valore testuale dell'elemento statistico."@it .

pa-recruit:votoConseguito a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "voto conseguito"@it ;
    rdfs:domain pa-recruit:QualificaAccademica ;
    rdfs:range xsd:integer ;
    rdfs:comment "Voto con cui è stata conseguita la qualifica accademica."@it .

pa-recruit:votoMassimoConseguibile a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "voto massimo conseguibile"@it ;
    rdfs:domain pa-recruit:QualificaAccademica ;
    rdfs:range xsd:integer ;
    rdfs:comment "Punteggio massimo conseguibile nell'ambito del corso accademico frequentato."@it .

pa-recruit:votoTestuale a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "voto testuale"@it ;
    rdfs:domain pa-recruit:QualificaAccademica ;
    rdfs:range xsd:string ;
    rdfs:comment "Voto conseguito espresso in formato testuale."@it .

### Classes

CLV:AdminUnitComponent a owl:Class .

COV:Organization a owl:Class .

COV:PublicOrganization a owl:Class .

CPV:Alive a owl:Class .

L0:Sequence a owl:Class .

pa-recruit:Allegato a owl:Class ;
    rdfs:label "Allegato"@it ;
    rdfs:comment "Documento integrativo di una lettera o una pratica per fornire informazioni aggiuntive o completarne il contenuto."@it .

pa-recruit:AllegatoCandidatura a owl:Class ;
    rdfs:label "Allegato candidatura"@it ;
    rdfs:subClassOf pa-recruit:Allegato ;
    rdfs:comment "Documento che accompagna la candidatura di un partecipante contenente informazioni e documenti richiesti per la procedura selettiva."@it .

pa-recruit:AllegatoPubblicazioneReclutamento a owl:Class ;
    rdfs:label "Allegato pubblicazione reclutamento"@it ;
    rdfs:subClassOf pa-recruit:Allegato ;
    rdfs:comment "Documento correlato alla pubblicazione di procedure selettive di reclutamento che fornisce dettagli aggiuntivi riuardanti il concorso."@it .

pa-recruit:AreaGeografica a owl:Class ;
    rdfs:label "Area geografica"@it ;
    rdfs:comment "Zona territoriale di assegnazione a cui saranno destinati i vincitori della procedura selettiva."@it .

pa-recruit:AttivitàDiInsegnamento a owl:Class ;
    rdfs:label "Attività di insegnamento"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pa-recruit:haEsperienzaDiInsegnamento ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:haIstitutodiInsegnamento ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:numeroAnniInsegnamento ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:numeroOreInsegnamento ;
            owl:someValuesFrom rdfs:Literal ] ;
    rdfs:comment "Incarico formativo svolto da un utente che può essere considerato nel processo di selezione."@it .

pa-recruit:AttoDiEquiparazioneQualificaEstera a owl:Class ;
    rdfs:label "Atto di equiparazione qualifica estera"@it ;
    rdfs:subClassOf [ a owl:Class ;
            owl:unionOf (
                    pa-recruit:AttoDiEquipollenzaQualifica
                    pa-recruit:AttoDiEquivalenzaQualifica ) ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:haAutoritàDiEmissione ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Atto di riconoscimento di una qualifica accademica o professionale conseguita presso una stato estero necessaria per poter svolgere la relativa attività professionale in Italia o partecipare a concorsi indetti dalla PA."@it .

pa-recruit:AttoDiEquipollenzaQualifica a owl:Class ;
    rdfs:label "Atto di equipollenza qualifica"@it ;
    owl:disjointWith pa-recruit:AttoDiEquivalenzaQualifica ;
    rdfs:comment "Sottoclasse di Atto di equiparazione qualifica accademica riferita al riconoscimento accademico del titolo posseduto ovvero all'equiparazione del suo valore legale."@it .

pa-recruit:AttoDiEquivalenzaQualifica a owl:Class ;
    rdfs:label "Atto di equivalenza qualifica"@it ;
    rdfs:comment "Sottoclasse di Atto di equiparazione qualifica accademica riferita al riconoscimento della validità del titolo posseduto al fine della partecipazione a corsi di studio o concorsi pubblici."@it .

pa-recruit:AvvisoDiMobilità a owl:Class ;
    rdfs:label "Avviso di mobilità"@it ;
    rdfs:subClassOf pa-recruit:PubblicazioneDiReclutamentoPA,
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:haCategoriaDiReclutamento ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:oneOf (
                            pa-recruit:avvisoDiMobilità ) ] ] ;
    rdfs:comment "Sottoclasse di \"Pubblicazione di reclutamento PA\" che raggruppa le pubblicazioni con categoria di reclutamento caratterizzate dal valore \"avviso di mobilità\", relativa a procedure selettive riservate a soggetti già appartenenti alla Pubblica Amministrazione."@it .

pa-recruit:AvvisoOIV a owl:Class ;
    rdfs:label "Avviso OIV"@it ;
    rdfs:subClassOf pa-recruit:PubblicazioneDiReclutamentoPA,
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:haCategoriaDiReclutamento ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:oneOf (
                            pa-recruit:avvisoOIV ) ] ] ;
    rdfs:comment "Sottoclasse di \"Pubblicazione di reclutamento\" PA che raggruppa le pubblicazioni con categoria di reclutamento valorizzata a \"avviso OIV\" (Organismi indipendenti di valutazione)."@it .

pa-recruit:BandoApprendistato a owl:Class ;
    rdfs:label "Bando apprendistato"@it ;
    rdfs:subClassOf pa-recruit:PubblicazioneDiReclutamentoPA,
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:haCategoriaDiReclutamento ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:oneOf (
                            pa-recruit:bandoApprendistato ) ] ] ;
    rdfs:comment "Sottoclasse di \"Pubblicazione di reclutamento PA\" che raggruppa le pubblicazioni con categoria di reclutamento caratterizzate dal valore \"bando apprendistato\", relativa a procedure di selezione per l'inserimento di personale con contratto di lavoro di apprendistato all'interno della Pubblica Amministrazione."@it .

pa-recruit:CandidaturaProceduraReclutamento a owl:Class ;
    rdfs:label "Candidatura procedura reclutamento"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pa-recruit:haCandidato ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:haProceduraReclutamentoDiCandidatura ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:haStatoDiCandidatura ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:identificativoCandidatura ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:identificativoDomandaDiCandidatura ;
            owl:someValuesFrom rdfs:Literal ] ;
    rdfs:comment "Domanda di partecipazione (application form) a una procedura di reclutamento."@it .

pa-recruit:CategoriaDellaCompetenza a owl:Class ;
    rdfs:label "Categoria della competenza"@it ;
    rdfs:comment "Classifica le categorie in cui si articolano le competenze."@it .

pa-recruit:CategoriaDiReclutamento a owl:Class ;
    rdfs:label "Categoria di reclutamento"@it ;
    rdfs:comment "Classificazione dei concorsi e bandi in base a specifici ambiti, modalità o settori."@it .

pa-recruit:CategoriaPatenteDiGuida a owl:Class ;
    rdfs:label "Categoria patente di guida"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pa-recruit:èCategoriaDiMezzoDiTrasporto ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Classifica le categorie di patente di guida."@it .

pa-recruit:CompetenzaLinguistica a owl:Class ;
    rdfs:label "Competenza linguistica"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pa-recruit:avvisoMadreLingua ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:haLinguaDiCompetenza ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Lingua straniera su cui un candidato ha compentenza."@it .

pa-recruit:Concorso a owl:Class ;
    rdfs:label "Concorso"@it ;
    rdfs:subClassOf pa-recruit:PubblicazioneDiReclutamentoPA,
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:haCategoriaDiReclutamento ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:oneOf (
                            pa-recruit:concorso ) ] ] ;
    rdfs:comment "Sottoclasse di \"Pubblicazione di reclutamento PA\" che raggruppa le pubblicazioni con categoria di reclutamento caratterizzate dal valore \"concorso\", relativa a bandi pubblici per l'assunzione di personale nella Pubblica Amministrazione."@it .

pa-recruit:ConcorsoDFP-FormezPA a owl:Class ;
    rdfs:label "Concorso DFP - Formez PA"@it ;
    rdfs:subClassOf pa-recruit:PubblicazioneDiReclutamentoPA,
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:haCategoriaDiReclutamento ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:oneOf (
                            pa-recruit:concorsoDFP-FormezPA ) ] ] ;
    rdfs:comment "Sottoclasse di \"Pubblicazione di reclutamento PA\" che raggruppa le pubblicazioni con categoria di reclutamento caratterizzate dal valore \"Concorso DFP-Formez PA\", relativa a bandi e avvisi gestiti con il supporto tecnico-operativo di Formez PA per conto delle amministrazioni centrali o locali ovvero banditi dalla Commissione interministeriale RIPAM."@it .

pa-recruit:ConsuntivoDiProcedura a owl:Class ;
    rdfs:label "Consuntivo di procedura"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf pa-recruit:haConsuntivoDiProcedura ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Totalizzazione delle dimensioni di misura della procedura di reclutamento: numero iscritti, pagamenti ricevuti, etc."@it .

pa-recruit:CurriculumVitae a owl:Class ;
    rdfs:label "Curriculum vitae"@it ;
    rdfs:comment "Classifica le diverse istanze di curriculum vitae ovvero gli aggregati di informazioni concernenti i percorsi formativi, le esperienze professionali, le attitudini e le competenze possedute da un partecipante e presentate nell'ambito di una procedura di reclutamento."@it .

pa-recruit:DescrittoreCompetenza a owl:Class ;
    rdfs:label "Descrittore competenza"@it ;
    rdfs:subClassOf pa-recruit:DescrittoreGenerico,
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:haCategoriaDellaCompetenza ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Sottoclasse di Descrittore generico dedicata a descrivere una competenza (skill)."@it .

pa-recruit:DescrittoreGenerico a owl:Class ;
    rdfs:label "Descrittore generico"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty L0:identifier ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty L0:name ;
            owl:someValuesFrom rdfs:Literal ] ;
    rdfs:comment "Istanzia la descrizione di un qualsiasi oggetto del mondo. È tipicamente costituito da un codice, un nome e una descrizione."@it .

pa-recruit:DescrittoreLingua a owl:Class ;
    rdfs:label "Descrittore lingua"@it ;
    rdfs:subClassOf pa-recruit:DescrittoreGenerico,
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:nomeLinguaInItaliano ;
            owl:someValuesFrom rdfs:Literal ] ;
    rdfs:comment "Sottoclasse di Descrittore generico dedicata alla descrizione di una lingua."@it .

pa-recruit:DescrittoreRuolo a owl:Class ;
    rdfs:label "Descrittore ruolo"@it ;
    rdfs:subClassOf pa-recruit:DescrittoreGenerico ;
    rdfs:comment "Definizione delle responsabilità e delle competenze proprie di un determinato ruolo professionale ricoperto."@it .

pa-recruit:ElementoStatistico a owl:Class ;
    rdfs:label "Elemento statistico"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty L0:name ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:valoreElementoStatisticoTestuale ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf pa-recruit:haElementoStatistico ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Dato quantitativo riferito a una determinata dimensione utilizzato nell'ambito di una serie statistica per analizzare e valutare i risultati delle procedure di reclutamento."@it .

pa-recruit:EsameDiSelezione a owl:Class ;
    rdfs:label "Esame di selezione"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pa-recruit:haTipoDiEsame ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:indicatoreDiEsame ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf pa-recruit:haEsameDiSelezione ] ;
            owl:someValuesFrom owl:Thing ] ;
    owl:disjointWith pa-recruit:SessioneDiEsame ;
    rdfs:comment "Prova che i candidati devono superare per essere selezionati nell'ambito di una procedura di reclutamento."@it .

pa-recruit:EsitoPartecipazioneSessioneDiEsame a owl:Class ;
    rdfs:label "Esito partecipazione sessione di esame"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf pa-recruit:haEsitoPartecipazioneSessioneDiEsame ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Risultato ottenuto da un candidato nella partecipazione a una prova selettiva."@it .

pa-recruit:EsperienzaDiFormazione a owl:Class ;
    rdfs:label "Esperienza di formazione"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pa-recruit:avvisoEsameFinale ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:haEventoDiFormazione ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:haIstitutoDiFormazione ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:haTipoRuoloInCorso ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:numeroOreFormazione ;
            owl:someValuesFrom rdfs:Literal ] ;
    rdfs:comment "Esperienza formativa a cui un canditato ha preso parte."@it .

pa-recruit:EsperienzaGenerica a owl:Class ;
    rdfs:label "Esperienza generica"@it ;
    rdfs:subClassOf TI:TimeIndexedEvent ;
    rdfs:comment "Esperienza professionale non specifica ma che può rilevare per il profilo del partecipante."@it .

pa-recruit:EsperienzaLavorativa a owl:Class ;
    rdfs:label "Esperienza lavorativa"@it ;
    rdfs:subClassOf TI:TimeIndexedEvent,
        [ a owl:Restriction ;
            owl:onProperty L0:identifier ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:haDatoreDiLavoro ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:haTipoDiContratto ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:haTipoOrarioDiLavoro ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Esperienza professionale di un partecipante che può essere considerata significativa nel processo di selezione."@it .

pa-recruit:EsperienzaLavorativaPA a owl:Class ;
    rdfs:label "Esperienza lavorativa PA"@it ;
    rdfs:subClassOf pa-recruit:EsperienzaLavorativa ;
    owl:disjointWith pa-recruit:EsperienzaLavorativaPrivata ;
    rdfs:comment "Esperienza professionale maturata all'interno della Pubblica Amministrazione."@it .

pa-recruit:EsperienzaLavorativaPrivata a owl:Class ;
    rdfs:label "Esperienza lavorativa privata"@it ;
    rdfs:subClassOf pa-recruit:EsperienzaLavorativa ;
    rdfs:comment "Esperienza professionale maturata in aziende private."@it .

pa-recruit:EventoDiFormazione a owl:Class ;
    rdfs:label "Evento di formazione"@it ;
    rdfs:subClassOf pa-recruit:EsperienzaGenerica,
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf pa-recruit:haEventoDiFormazione ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Evento formativo a cui un partecipante ha preso parte e che può contribuire alla valutazione nel processo di selezione."@it .

pa-recruit:GradoDiCompetenzaLingua a owl:Class ;
    rdfs:label "Grado di competenza lingua"@it ;
    rdfs:comment "Classifica le competenza nell'utilizzo di una lingua nell'ambito dei diversi usi della stessa (comprensione, parlato, scritto, …) secondo lo standard internazionale."@it .

pa-recruit:GraduatoriaDiReclutamento a owl:Class ;
    rdfs:label "Graduatoria di reclutamento"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pa-recruit:dataCreazioneGraduatoria ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:titoloGraduatoria ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:èGraduatoriaDiProceduraDiReclutamento ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Istanza della classifica dei candidati in base ai risultati ottenuti nel processo di selezione."@it .

pa-recruit:InformazioneAggiuntiva a owl:Class ;
    rdfs:label "Informazione aggiuntiva"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pa-recruit:haProprietàDellaCandidatura ;
            owl:someValuesFrom owl:Thing ] ;
    owl:disjointWith pa-recruit:PreferenzaAggiuntiva ;
    rdfs:comment "Dettagli supplementari forniti dal candidato che possono rilevare nel punteggio attribuito alla candidatura."@it .

pa-recruit:IntervalloSalariale a owl:Class ;
    rdfs:label "Intervallo salariale"@it ;
    rdfs:comment "Intervallo economico dello stipendio previsto per la posizione oggetto del reclutamento."@it .

pa-recruit:IstitutoDiFormazione a owl:Class ;
    rdfs:label "Istituto di formazione"@it ;
    rdfs:subClassOf COV:Organization,
        [ a owl:Restriction ;
            owl:onProperty CLV:hasAddress ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:haTipoDiIstitutoDiFormazione ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Classifica gli istituti di formazione nell'ambito del rilascio di una qualifica accademica. È sottoclasse di COV:Organization."@it .

pa-recruit:LivelloDiPubblicazione a owl:Class ;
    rdfs:label "Livello di pubblicazione"@it ;
    rdfs:comment "Classifica la platea e il grado di diffusione della pubblicazione."@it .

pa-recruit:ModalitàDiValutazione a owl:Class ;
    rdfs:label "Modalità di valutazione"@it ;
    rdfs:comment "Classificazione dei criteri e metodi utilizzati per valutare i candidati durante il processo di selezione."@it .

pa-recruit:PartecipanteSessioneEsame a owl:Class ;
    rdfs:label "Partecipante sessione esame"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pa-recruit:haEsitoPartecipazioneSessioneDiEsame ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf pa-recruit:haPartecipanteSessioneDiEsame ] ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf RO:holdsRoleInTime ] ;
            owl:someValuesFrom [ a owl:Restriction ;
                    owl:onProperty [ owl:inverseOf pa-recruit:haCandidato ] ;
                    owl:someValuesFrom owl:Thing ] ] ;
    owl:disjointWith pa-recruit:PosizioneInGraduatoriaDiReclutamento ;
    rdfs:comment "Ruolo assunto da un candidato al momento dell'effettiva partecipazione alla selezione per la procedura di reclutamento per cui ha presentato la candidatura."@it .

pa-recruit:PatenteDiGuida a owl:Class ;
    rdfs:label "Patente di guida"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pa-recruit:haCategoriaPatenteDiGuida ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:haPeriodoDiValiditàPatenteDiGuida ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:haTipoMezzoDiTrasporto ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf pa-recruit:haPatenteDiGuida ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Classifica le patenti di guida di mezzi di trasporto possedute da una persona."@it .

pa-recruit:PeriodoDiValiditàPatenteDiGuida a owl:Class ;
    rdfs:label "Periodo di validità patente di guida"@it ;
    rdfs:subClassOf L0:Sequence,
        TI:TimeInterval,
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf pa-recruit:haPeriodoDiValiditàPatenteDiGuida ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Classifica la sequenza dei periodi di validità di una patente di guida."@it .

pa-recruit:PosizioneInGraduatoriaDiReclutamento a owl:Class ;
    rdfs:label "Posizione in graduatoria di reclutamento"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pa-recruit:èPosizioneInGraduatoria ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Posizione di un candidato all'interno della graduatoria della procedura selettiva."@it .

pa-recruit:PreferenzaAggiuntiva a owl:Class ;
    rdfs:label "Preferenza aggiuntiva"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pa-recruit:haProprietàDellaCandidatura ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Opzione che permette a un candidato di esprimere ulteriori dichiarazioni, se richieste nella candidatura."@it .

pa-recruit:PreferenzaAmbito a owl:Class ;
    rdfs:label "Preferenza ambito"@it ;
    rdfs:subClassOf pa-recruit:DescrittoreGenerico ;
    rdfs:comment "Indicazione da parte di un candidato riguardo all'ambito professionale in cui desidera essere assegnato."@it .

pa-recruit:PreferenzaLuogoDiLavoro a owl:Class ;
    rdfs:label "Preferenza luogo di lavoro"@it ;
    rdfs:subClassOf CLV:AdminUnitComponent,
        [ a owl:Restriction ;
            owl:onProperty CLV:lat ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty CLV:long ;
            owl:someValuesFrom rdfs:Literal ] ;
    rdfs:comment "Indicazione della sede di lavoro in cui un candidato preferirebbe essere assegnato."@it .

pa-recruit:ProcedureStraordinarie a owl:Class ;
    rdfs:label "Procedure straordinarie"@it ;
    rdfs:subClassOf pa-recruit:PubblicazioneDiReclutamentoPA,
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:haCategoriaDiReclutamento ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:oneOf (
                            pa-recruit:procedureStraordinarie ) ] ] ;
    rdfs:comment "Sottoclasse di Pubblicazione di reclutamento PA che raggruppa le pubblicazioni con categoria di reclutamento valorizzata a \"procedure straordinarie\"."@it .

pa-recruit:ProprietàDellaCandidatura a owl:Class ;
    rdfs:label "Proprietà della candidatura"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pa-recruit:etichettaDellaProprietà ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:valoreDellaProprietà ;
            owl:someValuesFrom rdfs:Literal ] ;
    rdfs:comment "Istanzia una proprietà o caratteristica del candidato che si vuole far rilevare nell'ambito di una candidatura."@it .

pa-recruit:ProvvedimentoIncaricoEstero a owl:Class ;
    rdfs:label "Provvedimento incarico estero"@it ;
    rdfs:comment "Nell'ambito di un impiego nella PA, classifica i provvedimenti e gli atti di destinazione dei dipendenti presso sedi o dipartimenti in paesi esteri."@it .

pa-recruit:PubblicazioneAccademica a owl:Class ;
    rdfs:label "Pubblicazione accademica"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pa-recruit:autoreDellaPubblicazione ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:avvisoAutorePubblicazioneSingolo ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:dataDellaPubblicazione ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:haTipoDiPubblicazione ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:nomeDellaPubblicazione ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:numeroPaginePubblicazione ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:titoloDellaPubblicazione ;
            owl:someValuesFrom rdfs:Literal ] ;
    rdfs:comment "Articolo o lavoro di ricerca di un candidato pubblicato su riviste specializzate, libri o tesi che può essere considerato nel processo di selezione."@it .

pa-recruit:PubblicazioneDiReclutamentoPA a owl:Class ;
    rdfs:label "Pubblicazione di reclutamento PA"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pa-recruit:haAreaDiReclutamento ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:haCategoriaDiReclutamento ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:haEntePubblicoCoinvolto ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:haStatoPubblicazioneDiReclutamento ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:èBanditaDaEntePubblico ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Annuncio ufficiale che informa cittadini e/o dipendenti pubblici riguardo a nuove opportunità di impiego nella Pubblica Amministrazione."@it .

pa-recruit:QualificaAccademica a owl:Class ;
    rdfs:label "Qualifica accademica"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pa-recruit:durataCorsoDiStudio ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:haTipoDiQualifica ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:rilasciataDaIstitutoDiFormazione ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Attestato ufficiale rilasciato da un'istituzione scolastica o accademica accreditata, che certifica il superamento di un percorso formativo e il conseguimento delle competenze acquisite, con valore legale nel sistema educativo di istruzione e formazione."@it .

pa-recruit:RegolaDiAmmissioneProcedura a owl:Class ;
    rdfs:label "Regola di ammissione procedura"@it ;
    rdfs:comment "Requisito specifico per l'ammissione a una procedura selettiva."@it .

pa-recruit:RequisitoDiPartecipazione a owl:Class ;
    rdfs:label "Requisito di partecipazione"@it ;
    rdfs:comment "Condizione che un candidato deve soddisfare per poter partecipare a una procedura di reclutamento."@it .

pa-recruit:SceltaPA-Sede a owl:Class ;
    rdfs:label "Scelta PA-Sede"@it ;
    rdfs:subClassOf pa-recruit:PubblicazioneDiReclutamentoPA,
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:haCategoriaDiReclutamento ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:oneOf (
                            pa-recruit:sceltaPA-Sede ) ] ] ;
    rdfs:comment "Sottoclasse di Pubblicazione di reclutamento PA che raggruppa le pubblicazioni con categoria di reclutamento valorizzata a \"scelta PA-Sede\"."@it .

pa-recruit:SelezioneProfessionistiEdEsperti a owl:Class ;
    rdfs:label "Selezione professionisti ed esperti"@it ;
    rdfs:subClassOf pa-recruit:PubblicazioneDiReclutamentoPA,
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:haCategoriaDiReclutamento ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:oneOf (
                            pa-recruit:selezioneProfessionistiEdEsperti ) ] ] ;
    rdfs:comment "Sottoclasse di \"Pubblicazione di reclutamento PA\" che raggruppa le pubblicazioni con categoria di reclutamento caratterizzate dal valore \"selezione professionisti ed esperti\", relativa alle procedure finalizzate al reclutamento di profili specialistici e professionali."@it .

pa-recruit:SerieStatistica a owl:Class ;
    rdfs:label "Serie statistica"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty L0:name ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:haElementoStatistico ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf pa-recruit:haSerieStatisticaSuPubblicazione ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Istanza di collezione di elementi statistici utilizzati per analizzare le tendenze nel reclutamento del personale."@it .

pa-recruit:SessioneDiEsame a owl:Class ;
    rdfs:label "Sessione di esame"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty CLV:hasAddress ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf pa-recruit:haSessioneDiEsame ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Evento in cui i candidati sostengono le prove di selezione."@it .

pa-recruit:StatisticaPubblicazioneReclutamentoPA a owl:Class ;
    rdfs:label "Statistica pubblicazione reclutamento PA"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pa-recruit:haSerieStatisticaSuPubblicazione ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:nomeDelCampioneStatistico ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:sottotitoloDellaStatistica ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:titoloDellaStatistica ;
            owl:someValuesFrom rdfs:Literal ] ;
    rdfs:comment "Istanza di serie statistiche relativi alle pubblicazioni di concorsi e bandi di reclutamento nella Pubblica Amministrazione."@it .

pa-recruit:StatoApertoDiPubblicazioneDiReclutamento a owl:Class ;
    rdfs:label "Stato aperto di pubblicazione di reclutamento"@it ;
    rdfs:subClassOf pa-recruit:StatoPubblicazioneDiReclutamento ;
    rdfs:comment "Sottoclasse di \"stato pubblicazione di reclutamento\" che raggruppa le istanze in condizione di \"aperto\" ovvero la pubblicazione è attiva, ossia è possibile ancora candidarsi."@it .

pa-recruit:StatoBozzaDiPubblicazioneDiReclutamento a owl:Class ;
    rdfs:label "Stato bozza di pubblicazione di reclutamento"@it ;
    rdfs:subClassOf pa-recruit:StatoPubblicazioneDiReclutamento ;
    rdfs:comment "Sottoclasse di \"stato pubblicazione di reclutamento\" che raggruppa le istanze in condizione di \"bozza\" ovvero la procedura è in fase di preparazione e non è ancora pubblicata."@it .

pa-recruit:StatoChiusoDiPubblicazioneDiReclutamento a owl:Class ;
    rdfs:label "Stato chiuso di pubblicazione di reclutamento"@it ;
    rdfs:subClassOf pa-recruit:StatoPubblicazioneDiReclutamento ;
    rdfs:comment "Sottoclasse di \"stato pubblicazione di reclutamento\" che raggruppa le istanze in condizione di \"chiuso\" ovvero la pubblicazione non è più attiva e non è più possibile candidarsi."@it .

pa-recruit:StatoDiCandidatura a owl:Class ;
    rdfs:label "Stato di candidatura"@it ;
    rdfs:subClassOf TI:TimeIndexedEvent ;
    rdfs:comment "Oggettivazione della condizione di una candidatura rispetto al tempo."@it .

pa-recruit:StatoEliminatoDiPubblicazioneDiReclutamento a owl:Class ;
    rdfs:label "Stato eliminato di pubblicazione di reclutamento"@it ;
    rdfs:subClassOf pa-recruit:StatoPubblicazioneDiReclutamento ;
    rdfs:comment "Sottoclasse di \"stato pubblicazione di reclutamento\" che raggruppa le istanze relative a pubblicazioni definitivamente rimosse."@it .

pa-recruit:StatoInPubblicazioneDiPubblicazioneDiReclutamento a owl:Class ;
    rdfs:label "Stato in pubblicazione di pubblicazione di reclutamento"@it ;
    rdfs:subClassOf pa-recruit:StatoPubblicazioneDiReclutamento ;
    rdfs:comment "Sottoclasse di \"stato pubblicazione di reclutamento\" che raggruppa le istanze in fase di pubblicazione."@it .

pa-recruit:StatoPubblicazioneDiReclutamento a owl:Class ;
    rdfs:label "Stato pubblicazione di reclutamento"@it ;
    rdfs:subClassOf TI:TimeIndexedEvent,
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:haStatusDiProceduraReclutamento ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Oggettivazione della condizione di una pubblicazione di reclutamento rispetto al tempo."@it .

pa-recruit:StatusDiProceduraReclutamento a owl:Class ;
    rdfs:label "Status di procedura reclutamento"@it ;
    rdfs:comment "Classificazione della condizione che una pubblicazione di una procedura di reclutamento può assumere nel tempo."@it .

pa-recruit:TassaIscrizione a owl:Class ;
    rdfs:label "Tassa iscrizione"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pa-recruit:haSoggettoPagatore ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf pa-recruit:haPagamentoTassaIscrizione ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Importo richiesto al candidato per iscriversi al concorso pubblico."@it .

pa-recruit:TipoDiAttività a owl:Class ;
    rdfs:label "Tipo di attività"@it ;
    rdfs:comment "Tipologia di lavoro o incarico per cui viene indetta la procedura selettiva."@it .

pa-recruit:TipoDiAutore a owl:Class ;
    rdfs:label "Tipo di autore"@it ;
    rdfs:comment "Classifica un autore in base al suo coinvolgimento nell'ambito di una pubblicazione."@it .

pa-recruit:TipoDiAzienda a owl:Class ;
    rdfs:label "Tipo di azienda"@it ;
    rdfs:comment "Classifica le tipologie delle aziende."@it .

pa-recruit:TipoDiContratto a owl:Class ;
    rdfs:label "Tipo di contratto"@it ;
    rdfs:comment "Classifica le tipologie di contratto di lavoro."@it .

pa-recruit:TipoDiCorso a owl:Class ;
    rdfs:label "Tipo di corso"@it ;
    rdfs:comment "Classifica le tipologie di corso di formazione anche relativamente al titolo conseguito al termine della frequenza dello stesso."@it .

pa-recruit:TipoDiEsame a owl:Class ;
    rdfs:label "Tipo di esame"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf pa-recruit:haTipoDiEsame ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Classifica le diverse tipologie di esame."@it .

pa-recruit:TipoDiIstitutoDiFormazione a owl:Class ;
    rdfs:label "Tipo di istituto di formazione"@it ;
    rdfs:comment "Classifica le tipologie di istituti di formazione."@it .

pa-recruit:TipoDiMezzoDiTrasporto a owl:Class ;
    rdfs:label "Tipo di mezzo di trasporto"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf pa-recruit:èCategoriaDiMezzoDiTrasporto ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Classifica le diverse tipologie di mezzo di trasporto che una persona può condurre."@it .

pa-recruit:TipoDiPubblicazione a owl:Class ;
    rdfs:label "Tipo di pubblicazione"@it ;
    rdfs:comment "Classifica le tipologie associate ad una pubblicazione."@it .

pa-recruit:TipoDiQualifica a owl:Class ;
    rdfs:label "Tipo di qualifica"@it ;
    rdfs:comment "Classifica le tipologie di qualifiche accademiche."@it .

pa-recruit:TipoOrarioDiLavoro a owl:Class ;
    rdfs:label "Tipo orario di lavoro"@it ;
    rdfs:comment "Classifica le tipologie di orario di lavoro (full time, part time, …)"@it .

pa-recruit:TipoRuoloInCorso a owl:Class ;
    rdfs:label "Tipo ruolo in corso"@it ;
    rdfs:comment "Classifica il ruolo ricoperto nell'ambito di un corso di formazione (docente, discente, …)"@it .

pa-recruit:ValorizzazioneRegolaAmmissione a owl:Class ;
    rdfs:label "Valorizzazione regola ammissione"@it ;
    rdfs:subClassOf pa-recruit:ValorizzazioneRequisito,
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:haRegolaInValorizzazione ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf pa-recruit:haValorizzazioneRegolaDiAmmissione ] ;
            owl:someValuesFrom owl:Thing ] ;
    owl:disjointWith pa-recruit:ValorizzazioneRequisitoDiPartecipazione ;
    rdfs:comment "Valorizzazione di una regola di ammissione per una specifica candidatura."@it .

pa-recruit:ValorizzazioneRequisito a owl:Class ;
    rdfs:label "Valorizzazione requisito"@it ;
    rdfs:subClassOf [ a owl:Class ;
            owl:unionOf (
                    pa-recruit:ValorizzazioneRegolaAmmissione
                    pa-recruit:ValorizzazioneRequisitoDiPartecipazione ) ],
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:valoreDelRequisitoPerCandidatura ;
            owl:someValuesFrom rdfs:Literal ] ;
    rdfs:comment "Generalizzazione della valorizzazione dei requisiti, generici e specifici, attribuiti alle candidature."@it .

pa-recruit:ValorizzazioneRequisitoDiPartecipazione a owl:Class ;
    rdfs:label "Valorizzazione requisito di partecipazione"@it ;
    rdfs:subClassOf pa-recruit:ValorizzazioneRequisito,
        [ a owl:Restriction ;
            owl:onProperty pa-recruit:haRequisitoInValorizzazione ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf pa-recruit:haValorizzazioneRequisitoDiPartecipazione ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Valorizzazione di un requisito di partecipazione per una specifica candidatura."@it .

TI:TimeIndexedEvent a owl:Class .

TI:TimeInterval a owl:Class .

[] a owl:Class ;
    rdfs:subClassOf pa-recruit:CategoriaDiReclutamento ;
    owl:oneOf (
            pa-recruit:avvisoDiMobilità ) .

[] a owl:Class ;
    rdfs:subClassOf pa-recruit:CategoriaDiReclutamento ;
    owl:oneOf (
            pa-recruit:avvisoOIV ) .

[] a owl:Class ;
    rdfs:subClassOf pa-recruit:CategoriaDiReclutamento ;
    owl:oneOf (
            pa-recruit:bandoApprendistato ) .

[] a owl:Class ;
    rdfs:subClassOf pa-recruit:CategoriaDiReclutamento ;
    owl:oneOf (
            pa-recruit:concorso ) .

[] a owl:Class ;
    rdfs:subClassOf pa-recruit:CategoriaDiReclutamento ;
    owl:oneOf (
            pa-recruit:concorsoDFP-FormezPA ) .

[] a owl:Class ;
    rdfs:subClassOf pa-recruit:CategoriaDiReclutamento ;
    owl:oneOf (
            pa-recruit:procedureStraordinarie ) .

[] a owl:Class ;
    rdfs:subClassOf pa-recruit:CategoriaDiReclutamento ;
    owl:oneOf (
            pa-recruit:sceltaPA-Sede ) .

[] a owl:Class ;
    rdfs:subClassOf pa-recruit:CategoriaDiReclutamento ;
    owl:oneOf (
            pa-recruit:selezioneProfessionistiEdEsperti ) .

### Individuals

<https://w3id.org/italia/data/organization/public-organization/td> a dcatapit:Agent,
        foaf:Agent,
        owl:NamedIndividual ;
    dct:identifier "TD" ;
    foaf:name "Digital Transformation Team"@en,
        "Team per la Trasformazione Digitale"@it .

<https://w3id.org/italia/public-administration-governance/data/organization/dfp> a COV:PublicOrganization,
        dcatapit:Agent,
        foaf:Agent,
        owl:NamedIndividual ;
    rdfs:label "Department of Civil Service of the Presidency of the Council of Ministers"@en,
        "Dipartimento della Funzione Pubblica della Presidenza del Consiglio dei Ministri"@it ;
    dct:identifier "dfp" ;
