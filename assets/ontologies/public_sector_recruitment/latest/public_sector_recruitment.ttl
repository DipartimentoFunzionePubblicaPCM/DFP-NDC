pa-recruit: a owl:Ontology ;
    owl:versionIRI pa-recruit:1.0 ;
    owl:imports CLV:,
        COV:,
        CPV:,
        L0:,
        RO:,
        RPO:,
        SM:,
        TI: ;
    rdfs:label "inPA Recruitment Portal Ontology"@en,
        "Ontologia del Dipartimento della Funzione Pubblica"@it ;
    rdfs:comment "Ontologia dei processi di reclutamento nel Portale inPA (Portale unico del reclutamento – in Pubblica Amministrazione) del Ministero per la Pubblica Amministrazione ed in particolare del Dipartimento della Funzione Pubblica."@it,
        "The inPA Recruitment Portal Ontology describes some of the main concepts of the Recruitment Portal"@en ;
    owl:versionInfo "Version 1.0 - Modified 02 March 2026"@en,
        "Versione 1.0 - Modificata il 2 Marzo 2026"@it ;
    rdfs:isDefinedBy pa-recruit: ;
    adms:acronym "dfp" ;
    adms:hasContributor <https://w3id.org/italia/data/organization/public-organization/td> ;
    adms:hasFormalityLevel adms:Formal ;
    adms:hasKeyClass pa-recruit:CandidaturaProceduraReclutamento,
        pa-recruit:CategoriaDiReclutamento,
        pa-recruit:CurriculumVitae,
        pa-recruit:PubblicazioneDiReclutamentoPA,
        pa-recruit:SessioneDiEsame ;
    adms:hasOntologyLanguage adms:OWL ;
    adms:hasSemanticAssetDistribution <https://w3id.org/italia/public-administration-governance/data/public_sector_recruitment/distribution/PARECRUIT-N-TRIPLES>,
        <https://w3id.org/italia/public-administration-governance/data/public_sector_recruitment/distribution/PARECRUIT-RDF-TURTLE>,
        <https://w3id.org/italia/public-administration-governance/data/public_sector_recruitment/distribution/PARECRUIT-RDF-XML> ;
    adms:hasTask adms:AnnotationTask,
        adms:QueryFormulationTask,
        adms:SearchTask ;
    adms:last pa-recruit:1.0 ;
    adms:officialURI "https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment"^^xsd:anyURI ;
    adms:prefix "pa-recruit" ;
    adms:semanticAssetInUse <https://w3id.org/italia/data/project/NDC> ;
    adms:status "draft" ;
    adms:target "Cittadini"@it,
        "Imprese"@it,
        "Pubbliche Amministrazioni"@it ;
    adms:type adms:ServiceOnytology ;
    dcat:contactPoint <https://w3id.org/italia/public-administration-governance/data/organization/dfpDati> ;
    dcat:keyword "Candidatura Procedura Reclutamento"@it,
        "Categoria Di Reclutamento"@it,
        "Curriculum Vitae"@it,
        "Sessione Di Esame"@it ;
    dcat:theme <http://publications.europa.eu/resource/authority/data-theme/SOCI> ;
    dct:accrualPeriodicity <http://publications.europa.eu/resource/authority/frequency/IRREG> ;
    dct:creator <https://w3id.org/italia/public-administration-governance/data/organization/dfp> ;
    dct:description "Ontologia dei processi di reclutamento nel Portale inPA (Portale unico del reclutamento – in Pubblica Amministrazione) del Ministero per la Pubblica Amministrazione ed in particolare del Dipartimento della Funzione Pubblica."@it,
        "The inPA Recruitment Portal Ontology describes some of the main concepts of the Recruitment Portal."@en ;
    dct:identifier "https://w3id.org/italia/public-administration-governance/onto/public_sector_recruitment" ;
    dct:issued "2026-03-02T00:00:00+00:00"^^xsd:dateTime ;
    dct:language <http://publications.europa.eu/resource/authority/language/ENG>,
        <http://publications.europa.eu/resource/authority/language/ITA> ;
    dct:modified "2026-03-02T00:00:00+00:00"^^xsd:dateTime ;
    dct:publisher <https://w3id.org/italia/public-administration-governance/data/organization/dfp> ;
    dct:rightsHolder <https://w3id.org/italia/public-administration-governance/data/organization/dfp> ;
    dct:title "inPA Recruitment Portal Ontology"@en,
        "Ontologia del Dipartimento della Funzione Pubblica"@it .

### Object Properties

CLV:hasAddress a owl:ObjectProperty .

CLV:hasLowerRank a owl:ObjectProperty .

pa-recruit:haAllegatoCandidatura a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha allegato candidatura"@it ;
    rdfs:domain pa-recruit:CandidaturaProceduraReclutamento ;
    rdfs:range pa-recruit:AllegatoCandidatura ;
    rdfs:comment "Specifica che una candidatura per una procedura di reclutamento ha un allegato associato."@it .

pa-recruit:haAllegatoPubblicazioneReclutamento a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha allegato pubblicazione reclutamento"@it ;
    rdfs:domain pa-recruit:PubblicazioneDiReclutamentoPA ;
    rdfs:range pa-recruit:AllegatoPubblicazioneReclutamento ;
    rdfs:comment "Indica che una pubblicazione di reclutamento ha un allegato associato."@it .

pa-recruit:haAreaDiReclutamento a owl:ObjectProperty ;
    rdfs:label "ha area di reclutamento"@it ;
    rdfs:domain pa-recruit:PubblicazioneDiReclutamentoPA ;
    rdfs:range pa-recruit:AreaGeografica ;
    rdfs:comment "Indica l'area geografica a cui è dedicata la procedura di reclutamento."@it .

pa-recruit:haAreaScientificaDottorato a owl:FunctionalProperty,
        owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha area scientifica dottorato"@it ;
    rdfs:domain pa-recruit:QualificaAccademica ;
    rdfs:range pa-recruit:DescrittoreGenerico ;
    rdfs:comment "Collega una qualifica accademica a un'area scientifica specifica di dottorato."@it .

pa-recruit:haAttivitàDiInsegnamento a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha attività di insegnamento"@it ;
    rdfs:domain pa-recruit:CurriculumVitae ;
    rdfs:range pa-recruit:AttivitàDiInsegnamento ;
    rdfs:comment "Indica che un candidato ha svolto attività di insegnamento."@it .

pa-recruit:haAutoritàDiEmissione a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha autorità di emissione"@it ;
    rdfs:domain pa-recruit:AttoDiEquiparazioneQualificaEstera ;
    rdfs:range COV:PublicOrganization ;
    rdfs:comment "Lega un atto di equiparazione qualifica estera all'istituzione pubblica che lo ha emesso."@it .

pa-recruit:haCandidato a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha candidato"@it ;
    rdfs:domain pa-recruit:CandidaturaProceduraReclutamento ;
    rdfs:range CPV:Alive ;
    rdfs:comment "Lega una candidatura alla persona che si è candidata."@it .

pa-recruit:haCategoriaDellaCompetenza a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha categoria della competenza"@it ;
    rdfs:domain pa-recruit:DescrittoreCompetenza ;
    rdfs:range pa-recruit:CategoriaDellaCompetenza ;
    rdfs:comment "Lega un descrittore di competenza alla sua categoria"@it .

pa-recruit:haCategoriaDiReclutamento a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha categoria di reclutamento"@it ;
    rdfs:domain pa-recruit:PubblicazioneDiReclutamentoPA ;
    rdfs:range pa-recruit:CategoriaDiReclutamento ;
    rdfs:comment "Collega una pubblicazione di reclutamento a una categoria specifica di reclutamento."@it .

pa-recruit:haCategoriaPatenteDiGuida a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha categoria patente di guida"@it ;
    rdfs:domain pa-recruit:PatenteDiGuida ;
    rdfs:range pa-recruit:CategoriaPatenteDiGuida ;
    rdfs:comment "Lega una patente di guida alla relativa categoria."@it .

pa-recruit:haCicloDiDottorato a owl:FunctionalProperty,
        owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha ciclo di dottorato"@it ;
    rdfs:domain pa-recruit:QualificaAccademica ;
    rdfs:range pa-recruit:DescrittoreGenerico ;
    rdfs:comment "Collega una qualifica accademica a un ciclo di dottorato specifico."@it .

pa-recruit:haCompetenzaAccademica a owl:FunctionalProperty,
        owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha competenza accademica"@it ;
    rdfs:domain pa-recruit:QualificaAccademica ;
    rdfs:range pa-recruit:DescrittoreCompetenza ;
    rdfs:comment "Indica che una qualifica accademica è associata a una specifica competenza."@it .

pa-recruit:haCompetenzaEsperienzaGenerica a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha competenza esperienza generica"@it ;
    rdfs:domain pa-recruit:EsperienzaGenerica ;
    rdfs:range pa-recruit:DescrittoreCompetenza ;
    rdfs:comment "Indica che ad un'esperienza generica è associata a una competenza."@it .

pa-recruit:haCompetenzaEsperienzaLavorativa a owl:FunctionalProperty,
        owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha competenza esperienza lavorativa"@it ;
    rdfs:domain pa-recruit:EsperienzaLavorativa ;
    rdfs:range pa-recruit:DescrittoreCompetenza ;
    rdfs:comment "Collega un'esperienza lavorativa a una competenza specifica."@it .

pa-recruit:haCompetenzaExtracurriculare a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha competenza extracurriculare"@it ;
    rdfs:domain pa-recruit:CurriculumVitae ;
    rdfs:range pa-recruit:DescrittoreCompetenza ;
    rdfs:comment "Indica che un candidato ha competenze acquisite in attività extracurricolari."@it .

pa-recruit:haCompetenzaLinguistica a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha competenza linguistica"@it ;
    rdfs:domain pa-recruit:CurriculumVitae ;
    rdfs:range pa-recruit:CompetenzaLinguistica ;
    rdfs:comment "Indica che un candidato possiede una competenza linguistica specifica."@it .

pa-recruit:haCompetenzaPubblicazione a owl:FunctionalProperty,
        owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha competenza pubblicazione"@it ;
    rdfs:domain pa-recruit:PubblicazioneAccademica ;
    rdfs:range pa-recruit:DescrittoreCompetenza ;
    rdfs:comment "Collega una pubblicazione accademica a una competenza specifica."@it .

pa-recruit:haConsuntivoDiProcedura a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha consuntivo di procedura"@it ;
    rdfs:domain pa-recruit:PubblicazioneDiReclutamentoPA ;
    rdfs:range pa-recruit:ConsuntivoDiProcedura ;
    rdfs:comment "Lega una pubblicazione di procedura di reclutamento alle informazioni di consuntivazione."@it .

pa-recruit:haCurriculumVitae a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha curriculum vitae"@it ;
    rdfs:domain CPV:Alive ;
    rdfs:range pa-recruit:CurriculumVitae ;
    rdfs:comment "Lega un candidato ad un suo curriculum vitae."@it .

pa-recruit:haCurriculumVitaeDiCandidatura a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha curriculum vitae di candidatura"@it ;
    rdfs:domain pa-recruit:CandidaturaProceduraReclutamento ;
    rdfs:range pa-recruit:CurriculumVitae ;
    rdfs:comment "Lega una candidatura al curriculum vitae in essa presentato."@it .

pa-recruit:haDatoreDiLavoro a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha datore di lavoro"@it ;
    rdfs:domain pa-recruit:EsperienzaLavorativa ;
    rdfs:range COV:Organization ;
    rdfs:comment "Lega una esperienza lavorativa al datore di lavoro presso cui è stata svolta."@it .

pa-recruit:haDescrittoreRuolo a owl:FunctionalProperty,
        owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha descrittore ruolo"@it ;
    rdfs:domain pa-recruit:EsperienzaLavorativa ;
    rdfs:range pa-recruit:DescrittoreRuolo ;
    rdfs:comment "Collega un'esperienza lavorativa a un descrittore del ruolo svolto in quella specifica esperienza."@it .

pa-recruit:haElementoStatistico a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha elemento statistico"@it ;
    rdfs:domain pa-recruit:SerieStatistica ;
    rdfs:range pa-recruit:ElementoStatistico ;
    rdfs:comment "Collega una serie statistica a un elemento statistico specifico."@it .

pa-recruit:haEntePubblicoCoinvolto a owl:ObjectProperty ;
    rdfs:label "ha ente pubblico coinvolto"@it ;
    rdfs:domain pa-recruit:PubblicazioneDiReclutamentoPA ;
    rdfs:range COV:PublicOrganization ;
    rdfs:comment "Indica l'ente pubblico coinvolto in una procedura di reclutamento pubblicata."@it .

pa-recruit:haEsameDiSelezione a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha esame di selezione"@it ;
    rdfs:domain pa-recruit:PubblicazioneDiReclutamentoPA ;
    rdfs:range pa-recruit:EsameDiSelezione ;
    rdfs:comment "Collega una pubblicazione di reclutamento a un esame di selezione specifico."@it .

pa-recruit:haEsitoPartecipazioneSessioneDiEsame a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha esito partecipazione sessione di esame"@it ;
    rdfs:domain pa-recruit:PartecipanteSessioneEsame ;
    rdfs:range pa-recruit:EsitoPartecipazioneSessioneDiEsame ;
    rdfs:comment "Lega un partecipante alla sessione di esame al relativo esito."@it .

pa-recruit:haEsperienzaDiFormazione a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha esperienza di formazione"@it ;
    rdfs:domain pa-recruit:CurriculumVitae ;
    rdfs:range pa-recruit:EsperienzaDiFormazione ;
    rdfs:comment "Collega un candidato a una specifica esperienza di formazione."@it .

pa-recruit:haEsperienzaDiInsegnamento a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha esperienza di insegnamento"@it ;
    rdfs:domain pa-recruit:AttivitàDiInsegnamento ;
    rdfs:range pa-recruit:EsperienzaGenerica ;
    rdfs:comment "Lega una attività di insegnamento al suo descrittore."@it .

pa-recruit:haEsperienzaGenerica a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha esperienza generica"@it ;
    rdfs:domain pa-recruit:CurriculumVitae ;
    rdfs:range pa-recruit:EsperienzaGenerica ;
    rdfs:comment "Indica che un candidato ha maturato un'esperienza di tipo generico."@it .

pa-recruit:haEsperienzaInDottorato a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha esperienza in dottorato"@it ;
    rdfs:domain pa-recruit:QualificaAccademica ;
    rdfs:range pa-recruit:DescrittoreGenerico ;
    rdfs:comment "Collega una qualifica accademica a un'esperienza specifica di dottorato."@it .

pa-recruit:haEsperienzaLavorativa a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha esperienza lavorativa"@it ;
    rdfs:domain pa-recruit:CurriculumVitae ;
    rdfs:range pa-recruit:EsperienzaLavorativa ;
    rdfs:comment "Collega un candidato a un'esperienza lavorativa specifica."@it .

pa-recruit:haEventoDiFormazione a owl:FunctionalProperty,
        owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha evento di formazione"@it ;
    rdfs:domain pa-recruit:EsperienzaDiFormazione ;
    rdfs:range pa-recruit:EventoDiFormazione ;
    rdfs:comment "Collega una esperienza di formazione all'evento di formazione in cui è stata conseguita."@it .

pa-recruit:haGradoDiCompetenzaLingua a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha grado di competenza lingua"@it ;
    rdfs:domain pa-recruit:CompetenzaLinguistica ;
    rdfs:range pa-recruit:GradoDiCompetenzaLingua ;
    rdfs:comment "Lega una competenza linguistica al suo grado."@it .

pa-recruit:haGradoDiComprensioneLingua a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha grado di comprensione lingua"@it ;
    rdfs:subPropertyOf pa-recruit:haGradoDiCompetenzaLingua ;
    rdfs:comment "Sotto proprietà che lega una competenza linguistica di comprensione al suo grado."@it .

pa-recruit:haGradoDiConversazioneLingua a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha grado di conversazione lingua"@it ;
    rdfs:subPropertyOf pa-recruit:haGradoDiCompetenzaLingua ;
    rdfs:comment "Sotto proprietà che lega una competenza linguistica di conversazione al suo grado."@it .

pa-recruit:haGradoDiLetturaLingua a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha grado di lettura lingua"@it ;
    rdfs:subPropertyOf pa-recruit:haGradoDiCompetenzaLingua ;
    rdfs:comment "Sotto proprietà che lega una competenza linguistica di lettura al suo grado."@it .

pa-recruit:haGradoDiParlatoLingua a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha grado di parlato lingua"@it ;
    rdfs:subPropertyOf pa-recruit:haGradoDiCompetenzaLingua ;
    rdfs:comment "Sotto proprietà che lega una competenza linguistica di lingua parlata al suo grado."@it .

pa-recruit:haGradoDiScritturaLingua a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha grado di scrittura lingua"@it ;
    rdfs:subPropertyOf pa-recruit:haGradoDiCompetenzaLingua ;
    rdfs:comment "Sotto proprietà che lega una competenza linguistica di scrittura al suo grado."@it .

pa-recruit:haInformazioneAggiuntiva a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha informazione aggiuntiva"@it ;
    rdfs:domain pa-recruit:CandidaturaProceduraReclutamento ;
    rdfs:range pa-recruit:InformazioneAggiuntiva ;
    rdfs:comment "Indica che una candidatura ha una informazione aggiuntiva associata."@it .

pa-recruit:haIntervalloSalariale a owl:FunctionalProperty,
        owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha intervallo salariale"@it ;
    rdfs:domain pa-recruit:PubblicazioneDiReclutamentoPA ;
    rdfs:range pa-recruit:IntervalloSalariale ;
    rdfs:comment "Collega una pubblicazione di reclutamento a un intervallo salariale specifico per la posizione prevista dalla procedura."@it .

pa-recruit:haIstitutoDiFormazione a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha istituto di formazione"@it ;
    rdfs:domain pa-recruit:EsperienzaDiFormazione ;
    rdfs:range COV:Organization ;
    rdfs:comment "Lega una esperienza di formazione all'istituto o organizzazione che l'ha erogata."@it .

pa-recruit:haIstitutodiInsegnamento a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha istituto di insegnamento"@it ;
    rdfs:domain pa-recruit:AttivitàDiInsegnamento ;
    rdfs:range COV:Organization ;
    rdfs:comment "Lega una esperienza di insegnamento all'istituto o organizzazione presso cui è stata svolta."@it .

pa-recruit:haLinguaDiCompetenza a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha lingua di competenza"@it ;
    rdfs:domain pa-recruit:CompetenzaLinguistica ;
    rdfs:range pa-recruit:DescrittoreLingua ;
    rdfs:comment "Collega una competenza linguistica a una lingua specifica."@it .

pa-recruit:haLivelloDiPubblicazione a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha livello di pubblicazione"@it ;
    rdfs:domain pa-recruit:PubblicazioneAccademica ;
    rdfs:range pa-recruit:LivelloDiPubblicazione ;
    rdfs:comment "Lega una pubblicazione accademica al suo livello."@it .

pa-recruit:haModalitàDiValutazione a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha modalità di valutazione"@it ;
    rdfs:domain pa-recruit:PubblicazioneDiReclutamentoPA ;
    rdfs:range pa-recruit:ModalitàDiValutazione ;
    rdfs:comment "Collega una pubblicazione di reclutamento a una modalità di valutazione specifica."@it .

pa-recruit:haPagamentoTassaIscrizione a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha pagamento tassa iscrizione"@it ;
    rdfs:domain pa-recruit:CandidaturaProceduraReclutamento ;
    rdfs:range pa-recruit:TassaIscrizione ;
    rdfs:comment "Indica che una candidatura ha un pagamento di tassa di iscrizione associato."@it .

pa-recruit:haPartecipanteSessioneDiEsame a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha partecipante sessione di esame"@it ;
    rdfs:domain pa-recruit:SessioneDiEsame ;
    rdfs:range pa-recruit:PartecipanteSessioneEsame ;
    rdfs:comment "Collega una sessione di esame a un partecipante alla sessione."@it .

pa-recruit:haPatenteDiGuida a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha patente di guida"@it ;
    rdfs:domain CPV:Alive ;
    rdfs:range pa-recruit:PatenteDiGuida ;
    rdfs:comment "Lega una persona alle patenti di guida conseguite."@it .

pa-recruit:haPeriodoDiValiditàPatenteDiGuida a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha periodo di validità patente di guida"@it ;
    rdfs:domain pa-recruit:PatenteDiGuida ;
    rdfs:range pa-recruit:PeriodoDiValiditàPatenteDiGuida ;
    rdfs:comment "Lega una patente di guida ai suoi periodi di validità nel tempo."@it .

pa-recruit:haPreferenzaAggiuntiva a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha preferenza aggiuntiva"@it ;
    rdfs:domain pa-recruit:CandidaturaProceduraReclutamento ;
    rdfs:range pa-recruit:PreferenzaAggiuntiva ;
    rdfs:comment "Indica che una candidatura ha una preferenza aggiuntiva associata."@it .

pa-recruit:haPreferenzaAmbito a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha preferenza ambito"@it ;
    rdfs:domain pa-recruit:CandidaturaProceduraReclutamento ;
    rdfs:range pa-recruit:PreferenzaAmbito ;
    rdfs:comment "Indica che una candidatura ha una preferenza per un ambito specifico."@it .

pa-recruit:haPreferenzaLuogoDiLavoro a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha preferenza luogo di lavoro"@it ;
    rdfs:domain pa-recruit:CandidaturaProceduraReclutamento ;
    rdfs:range pa-recruit:PreferenzaLuogoDiLavoro ;
    rdfs:comment "Indica che una candidatura ha una preferenza per un luogo di lavoro specifico."@it .

pa-recruit:haProceduraReclutamentoDiCandidatura a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha procedura reclutamento di candidatura"@it ;
    rdfs:domain pa-recruit:CandidaturaProceduraReclutamento ;
    rdfs:range pa-recruit:PubblicazioneDiReclutamentoPA ;
    rdfs:comment "Collega una candidatura alla relativa procedura di reclutamento pubblicata."@it .

pa-recruit:haProprietàDellaCandidatura a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha proprietà della candidatura"@it ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf (
                    pa-recruit:InformazioneAggiuntiva
                    pa-recruit:PreferenzaAggiuntiva ) ] ;
    rdfs:range pa-recruit:ProprietàDellaCandidatura ;
    rdfs:comment "Lega una preferenza o informazione aggiuntiva alla proprietà che la descrive."@it .

pa-recruit:haProvvedimentoIncaricoEstero a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha provvedimento incarico estero"@it ;
    rdfs:domain pa-recruit:EsperienzaLavorativaPA ;
    rdfs:range pa-recruit:ProvvedimentoIncaricoEstero ;
    rdfs:comment "Lega una esperienza lavorativa nella PA ad un provvedimento di incarico all'estero."@it .

pa-recruit:haPubblicazioneAccademica a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha pubblicazione accademica"@it ;
    rdfs:domain pa-recruit:CurriculumVitae ;
    rdfs:range pa-recruit:PubblicazioneAccademica ;
    rdfs:comment "Indica che un candidato ha una pubblicazione accademica associata."@it .

pa-recruit:haQualificaAccademica a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha qualifica accademica"@it ;
    rdfs:domain pa-recruit:CurriculumVitae ;
    rdfs:range pa-recruit:QualificaAccademica ;
    rdfs:comment "Indica che un candidato ha una qualifica accademica specifica."@it .

pa-recruit:haRegolaDiAmmissioneProcedura a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha regola di ammissione procedura"@it ;
    rdfs:domain pa-recruit:PubblicazioneDiReclutamentoPA ;
    rdfs:range pa-recruit:RegolaDiAmmissioneProcedura ;
    rdfs:comment "Collega una pubblicazione di reclutamento a una regola di ammissione specifica."@it .

pa-recruit:haRegolaInValorizzazione a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha regola in valorizzazione"@it ;
    rdfs:domain pa-recruit:ValorizzazioneRegolaAmmissione ;
    rdfs:range pa-recruit:RegolaDiAmmissioneProcedura ;
    rdfs:comment "Collega una valorizzazione di una regola di ammissione alla regola stessa."@it .

pa-recruit:haRequisitoDiReclutamento a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha requisito di reclutamento"@it ;
    rdfs:domain pa-recruit:PubblicazioneDiReclutamentoPA ;
    rdfs:range pa-recruit:RequisitoDiPartecipazione ;
    rdfs:comment "Indica che una pubblicazione di reclutamento ha un requisito di partecipazione associato."@it .

pa-recruit:haRequisitoInValorizzazione a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha requisito in valorizzazione"@it ;
    rdfs:domain pa-recruit:ValorizzazioneRequisitoDiPartecipazione ;
    rdfs:range pa-recruit:RequisitoDiPartecipazione ;
    rdfs:comment "Collega una valorizzazione di un requisito di partecipazione al requisito stesso."@it .

pa-recruit:haSerieStatisticaSuPubblicazione a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha serie statistica su pubblicazione"@it ;
    rdfs:domain pa-recruit:StatisticaPubblicazioneReclutamentoPA ;
    rdfs:range pa-recruit:SerieStatistica ;
    rdfs:comment "Collega una statistica di pubblicazione di reclutamento a una serie statistica specifica."@it .

pa-recruit:haSessioneDiEsame a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha sessione di esame"@it ;
    rdfs:domain pa-recruit:EsameDiSelezione ;
    rdfs:range pa-recruit:SessioneDiEsame ;
    rdfs:comment "Collega un esame di selezione a una sessione di esame specifica."@it .

pa-recruit:haSoggettoPagatore a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha soggetto pagatore"@it ;
    rdfs:domain pa-recruit:TassaIscrizione ;
    rdfs:range CPV:Alive ;
    rdfs:comment "Lega un pagamento alla persona che lo ha pagato"@it .

pa-recruit:haSpecificaDiPreferenzaLuogoDiLavoro a owl:ObjectProperty ;
    rdfs:label "ha specifica di preferenza luogo di lavoro"@it ;
    rdfs:subPropertyOf CLV:hasLowerRank ;
    rdfs:domain pa-recruit:PreferenzaLuogoDiLavoro ;
    rdfs:range pa-recruit:PreferenzaLuogoDiLavoro ;
    rdfs:comment "Lega una indicazione geografica del luogo di lavoro preferito ad un maggiore dettaglio geografico (esempio: da regione a provincia)."@it .

pa-recruit:haStatoDiCandidatura a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha stato di candidatura"@it ;
    rdfs:domain pa-recruit:CandidaturaProceduraReclutamento ;
    rdfs:range pa-recruit:StatoDiCandidatura ;
    rdfs:comment "Collega una candidatura a una sua condizione nel tempo."@it .

pa-recruit:haStatoPubblicazioneDiReclutamento a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha stato pubblicazione di reclutamento"@it ;
    rdfs:domain pa-recruit:PubblicazioneDiReclutamentoPA ;
    rdfs:range pa-recruit:StatoPubblicazioneDiReclutamento ;
    rdfs:comment "Collega una pubblicazione di reclutamento a una sua condizione nel tempo."@it .

pa-recruit:haStatusDiProceduraReclutamento a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha status di procedura reclutamento"@it ;
    rdfs:domain pa-recruit:StatoPubblicazioneDiReclutamento ;
    rdfs:range pa-recruit:StatusDiProceduraReclutamento ;
    rdfs:comment "Collega uno stato di pubblicazione a uno specifico status di procedura di reclutamento."@it .

pa-recruit:haTipoDiAttività a owl:ObjectProperty ;
    rdfs:label "ha tipo di attività"@it ;
    rdfs:domain pa-recruit:PubblicazioneDiReclutamentoPA ;
    rdfs:range pa-recruit:TipoDiAttività ;
    rdfs:comment "Collega una pubblicazione di reclutamento a un tipo di attività specifica obiettivo della procedura stessa."@it .

pa-recruit:haTipoDiAutore a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha tipo di autore"@it ;
    rdfs:domain pa-recruit:PubblicazioneAccademica ;
    rdfs:range pa-recruit:TipoDiAutore ;
    rdfs:comment "Lega una Pubblicazione accademica al tipo di autore."@it .

pa-recruit:haTipoDiAzienda a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha tipo di azienda"@it ;
    rdfs:domain pa-recruit:EsperienzaLavorativa ;
    rdfs:range pa-recruit:TipoDiAzienda ;
    rdfs:comment "Lega una Esperienza lavorativa al tipo di azienda presso cui si è svolta."@it .

pa-recruit:haTipoDiContratto a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha tipo di contratto"@it ;
    rdfs:domain pa-recruit:EsperienzaLavorativa ;
    rdfs:range pa-recruit:TipoDiContratto ;
    rdfs:comment "Lega una Esperienza lavorativa al tipo di contratto con cui è stata svolta."@it .

pa-recruit:haTipoDiCorso a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha tipo di corso"@it ;
    rdfs:domain pa-recruit:EsperienzaDiFormazione ;
    rdfs:range pa-recruit:TipoDiCorso ;
    rdfs:comment "Lega una Esperienza di formazione al tipo di corso frequentato."@it .

pa-recruit:haTipoDiEsame a owl:ObjectProperty ;
    rdfs:label "ha tipo di esame"@it ;
    rdfs:domain pa-recruit:EsameDiSelezione ;
    rdfs:range pa-recruit:TipoDiEsame ;
    rdfs:comment "Lega un esame di selezione alla sua tipologia."@it .

pa-recruit:haTipoDiIstitutoDiFormazione a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha tipo di istituto di formazione"@it ;
    rdfs:domain pa-recruit:IstitutoDiFormazione ;
    rdfs:range pa-recruit:TipoDiIstitutoDiFormazione ;
    rdfs:comment "Lega un istituto di formazione al suo tipo."@it .

pa-recruit:haTipoDiPubblicazione a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha tipo di pubblicazione"@it ;
    rdfs:domain pa-recruit:PubblicazioneAccademica ;
    rdfs:range pa-recruit:TipoDiPubblicazione ;
    rdfs:comment "Lega una Pubblicazione accademica al suo tipo."@it .

pa-recruit:haTipoDiQualifica a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha tipo di qualifica"@it ;
    rdfs:domain pa-recruit:QualificaAccademica ;
    rdfs:range pa-recruit:TipoDiQualifica ;
    rdfs:comment "Lega una Qualifica accademica al suo tipo."@it .

pa-recruit:haTipoMezzoDiTrasporto a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha tipo mezzo di trasporto"@it ;
    rdfs:domain pa-recruit:PatenteDiGuida ;
    rdfs:range pa-recruit:TipoDiMezzoDiTrasporto ;
    rdfs:comment "Lega una patente di guida al tipo di mezzo di trasporto di cui abilità la guida"@it .

pa-recruit:haTipoOrarioDiLavoro a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha tipo orario di lavoro"@it ;
    rdfs:domain pa-recruit:EsperienzaLavorativa ;
    rdfs:range pa-recruit:TipoOrarioDiLavoro ;
    rdfs:comment "Lega una Esperienza lavorativa al tipo di orario di lavoro con cui è stata svolta."@it .

pa-recruit:haTipoRuoloInCorso a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha tipo ruolo in corso"@it ;
    rdfs:domain pa-recruit:EsperienzaDiFormazione ;
    rdfs:range pa-recruit:TipoRuoloInCorso ;
    rdfs:comment "Lega una Esperienza di formazione al tipo di ruolo ricoperto nell'ambito di tale esperienza."@it .

pa-recruit:haValorizzazioneRegolaDiAmmissione a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha valorizzazione regola di ammissione"@it ;
    rdfs:domain pa-recruit:CandidaturaProceduraReclutamento ;
    rdfs:range pa-recruit:ValorizzazioneRegolaAmmissione ;
    rdfs:comment "Collega una candidatura a una valorizzazione di una regola di ammissione."@it .

pa-recruit:haValorizzazioneRequisitoDiPartecipazione a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha valorizzazione requisito di partecipazione"@it ;
    rdfs:domain pa-recruit:CandidaturaProceduraReclutamento ;
    rdfs:range pa-recruit:ValorizzazioneRequisitoDiPartecipazione ;
    rdfs:comment "Collega una candidatura a una valorizzazione di un requisito di partecipazione."@it .

pa-recruit:riferisceAttoDiEquiparazioneQualificaEstera a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "riferisce atto di equiparazione qualifica estera"@it ;
    rdfs:domain pa-recruit:QualificaAccademica ;
    rdfs:range pa-recruit:AttoDiEquiparazioneQualificaEstera ;
    rdfs:comment "Lega una Qualifica accademica con l'atto di equiparazione che l'ha validata."@it .

pa-recruit:rilasciataDaIstitutoDiFormazione a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "rilasciata da istituto di formazione"@it ;
    rdfs:domain pa-recruit:QualificaAccademica ;
    rdfs:range pa-recruit:IstitutoDiFormazione ;
    rdfs:comment "Lega una Qualifica accademica all'istituto di formazione che l'ha rilasciata."@it .

pa-recruit:èBanditaDaEntePubblico a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "è bandita da ente pubblico"@it ;
    rdfs:domain pa-recruit:PubblicazioneDiReclutamentoPA ;
    rdfs:range COV:PublicOrganization,
        [ a owl:Restriction ;
            owl:onProperty SM:hasEmail ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Indica l'ente pubblico che ha avviato una procedura di reclutamento attraverso la pubblicazione di un annuncio."@it .

pa-recruit:èCategoriaDiMezzoDiTrasporto a owl:ObjectProperty ;
    rdfs:label "è categoria di mezzo di trasporto"@it ;
    rdfs:domain pa-recruit:CategoriaPatenteDiGuida ;
    rdfs:range pa-recruit:TipoDiMezzoDiTrasporto ;
    rdfs:comment "Lega una categoria di patente di guida al mezzo di trasporto di cui abilita la guida."@it .

pa-recruit:èGraduatoriaDiProceduraDiReclutamento a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "è graduatoria di procedura di reclutamento"@it ;
    rdfs:domain pa-recruit:GraduatoriaDiReclutamento ;
    rdfs:range pa-recruit:PubblicazioneDiReclutamentoPA ;
    rdfs:comment "Collega una graduatoria alla relativa procedura di reclutamento pubblicata."@it .

pa-recruit:èPosizioneDiPartecipanteInGraduatoria a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "è posizione di partecipante in graduatoria"@it ;
    rdfs:domain pa-recruit:PosizioneInGraduatoriaDiReclutamento ;
    rdfs:range pa-recruit:PartecipanteSessioneEsame ;
    rdfs:comment "Collega una specifica posizione della graduatoria al relativo partecipante all'esame di selezione."@it .

pa-recruit:èPosizioneInGraduatoria a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "è posizione in graduatoria"@it ;
    rdfs:domain pa-recruit:PosizioneInGraduatoriaDiReclutamento ;
    rdfs:range pa-recruit:GraduatoriaDiReclutamento ;
    rdfs:comment "Collega una specifica posizione alla relativa graduatoria."@it .

RO:holdsRoleInTime a owl:ObjectProperty .

SM:hasEmail a owl:ObjectProperty .

### Datatypes

xsd:boolean a rdfs:Datatype .

xsd:dateTime a rdfs:Datatype .

xsd:float a rdfs:Datatype .

xsd:integer a rdfs:Datatype .

xsd:string a rdfs:Datatype .

### Data Properties

CLV:lat a owl:DatatypeProperty .

CLV:long a owl:DatatypeProperty .

L0:identifier a owl:DatatypeProperty .

L0:name a owl:DatatypeProperty .

pa-recruit:areaDisciplinareDottorato a owl:DatatypeProperty ;
    rdfs:label "area disciplinare dottorato"@it ;
    rdfs:domain pa-recruit:QualificaAccademica ;
    rdfs:range xsd:string ;
    rdfs:comment "Descrive l'area di specializzazione in cui è stato svolto il dottorato accademico."@it .

pa-recruit:ausiliUtilizzatiInSessione a owl:DatatypeProperty ;
    rdfs:label "ausili utilizzati in sessione"@it ;
    rdfs:domain pa-recruit:PartecipanteSessioneEsame ;
    rdfs:range xsd:string ;
    rdfs:comment "Eventuali ausili utilizzati dai portatori di disabilità durante la sessione di esame."@it .

pa-recruit:autoreDellaPubblicazione a owl:DatatypeProperty ;
    rdfs:label "autore della pubblicazione"@it ;
    rdfs:domain pa-recruit:PubblicazioneAccademica ;
    rdfs:range xsd:string ;
    rdfs:comment "Autore della pubblicazione accademica."@it .

pa-recruit:autoritàProvvedimentoEstero a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "autorità provvedimento estero"@it ;
    rdfs:domain pa-recruit:ProvvedimentoIncaricoEstero ;
    rdfs:range xsd:string ;
    rdfs:comment "Autorità emittente del provvedimento di assegnazione incarico all'estero."@it .

pa-recruit:avvisoAutorePubblicazioneSingolo a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "avviso autore pubblicazione singolo"@it ;
    rdfs:domain pa-recruit:PubblicazioneAccademica ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Indica che la pubblicazione accademica ha un solo autore."@it .

pa-recruit:avvisoCandidatureAcquisite a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "avviso candidature acquisite"@it ;
    rdfs:domain pa-recruit:PubblicazioneDiReclutamentoPA ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Evidenzia che le candidature alla procedure di reclutamento, in tutto o in parte, possono essere acquisite da un fornitore (portale) esterno."@it .

pa-recruit:avvisoDottoratoEstero a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "avviso dottorato estero"@it ;
    rdfs:domain pa-recruit:QualificaAccademica ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Indica che il dottorato è sto svolto all'estero."@it .

pa-recruit:avvisoEsameFinale a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "avviso esame finale"@it ;
    rdfs:domain pa-recruit:EsperienzaDiFormazione ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Indica se l'esperienza formativa prevedeva un esame finale."@it .

pa-recruit:avvisoEsperienzaAttuale a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "avviso esperienza attuale"@it ;
    rdfs:domain pa-recruit:EsperienzaGenerica ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Indica che l'esperienza è in corso al tempo della candidatura."@it .

pa-recruit:avvisoImpiegoAttuale a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "avviso impiego attuale"@it ;
    rdfs:domain pa-recruit:EsperienzaLavorativa ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Indica che l'esperienza lavorativa è in corso."@it .

pa-recruit:avvisoLavoroEstero a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "avviso lavoro estero"@it ;
    rdfs:domain pa-recruit:EsperienzaLavorativaPA ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Indica che l'esperienza lavorativa è stata svolta all'estero"@it .

pa-recruit:avvisoLode a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "avviso lode"@it ;
    rdfs:domain pa-recruit:QualificaAccademica ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Indica se la qualifica accademica è stata conseguita con lode."@it .

pa-recruit:avvisoMadreLingua a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "avviso madre lingua"@it ;
    rdfs:domain pa-recruit:CompetenzaLinguistica ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Indica che la lingua indicata è madrelingua per il candidato."@it .

pa-recruit:avvisoPagamentoRichiesto a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "avviso pagamento richiesto"@it ;
    rdfs:domain pa-recruit:PubblicazioneDiReclutamentoPA ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Segnala che la partecipazione alla procedura di reclutamento è a titolo oneroso."@it .

pa-recruit:avvisoQualificaEstera a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "avviso qualifica estera"@it ;
    rdfs:domain pa-recruit:QualificaAccademica ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Indica se la qualifica accademica è stata conseguita all'estero."@it .

pa-recruit:avvisoRisultatoSessionePubblicato a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "avviso risultato sessione pubblicato"@it ;
    rdfs:domain pa-recruit:SessioneDiEsame ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Segnala che il risultato della sessione di esame è stato pubblicato."@it .

pa-recruit:avvisoSuperamentoEsameDiStato a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "avviso superamento esame di stato"@it ;
    rdfs:domain pa-recruit:QualificaAccademica ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Indica se l'iscrizione ad un albo o registro prevedeva il superamento di un esame di abilitazione."@it .

pa-recruit:codiceOIVDiControllo a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "codice OIV di controllo"@it ;
    rdfs:subPropertyOf L0:identifier ;
    rdfs:domain pa-recruit:PubblicazioneDiReclutamentoPA ;
    rdfs:comment "Codice identificativo della procedura di reclutamento nell'ambito informativo degli Organismi Interni di Valutazione - OIV."@it .

pa-recruit:collegamentoAGU a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "collegamento a GU"@it ;
    rdfs:domain pa-recruit:PubblicazioneDiReclutamentoPA ;
    rdfs:range xsd:string ;
    rdfs:comment "Web link alla pubblicazione in gazzetta Ufficiale"@it .

pa-recruit:collegamentoASitoPA a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "collegamento a sito PA"@it ;
    rdfs:range xsd:string ;
    rdfs:comment "Web link alla procedura di reclutamento nel portale della Pubblica Amministrazione"@it .

pa-recruit:collegamentoDiReindirizzamento a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "collegamento di reindirizzamento"@it ;
    rdfs:domain pa-recruit:PubblicazioneDiReclutamentoPA ;
    rdfs:range xsd:string ;
    rdfs:comment "Web link di reindirizzamento alla procedura di reclutamento in portale esterno alla Pubblica Amministrazione."@it .

pa-recruit:dataAttoEquiparazioneQualifica a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "data atto equiparazione qualifica"@it ;
    rdfs:domain pa-recruit:AttoDiEquiparazioneQualificaEstera ;
    rdfs:range xsd:dateTime ;
    rdfs:comment "Data di emissione del provvedimento di equiparazione di una qualifica accademica estera."@it .

pa-recruit:dataCostruzioneGraduatoria a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "data costruzione graduatoria"@it ;
    rdfs:domain pa-recruit:GraduatoriaDiReclutamento ;
    rdfs:range xsd:dateTime ;
    rdfs:comment "Data di termine della definizione della graduatoria."@it .

pa-recruit:dataCreazioneDomanda a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "data creazione domanda"@it ;
    rdfs:domain pa-recruit:CandidaturaProceduraReclutamento ;
    rdfs:range xsd:dateTime ;
    rdfs:comment "Data di creazione della domanda di candidatura. Corrisponde alla startDate del relativo stato della domanda."@it .

pa-recruit:dataCreazioneGraduatoria a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "data creazione graduatoria"@it ;
    rdfs:domain pa-recruit:GraduatoriaDiReclutamento ;
    rdfs:range xsd:dateTime ;
    rdfs:comment "Data di inizio definizione della graduatoria."@it .

pa-recruit:dataDellaPubblicazione a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "data della pubblicazione"@it ;
    rdfs:domain pa-recruit:PubblicazioneAccademica ;
    rdfs:range xsd:dateTime ;
    rdfs:comment "Data della pubblicazione accademica."@it .

pa-recruit:dataDiConseguimentoQualifica a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "data di conseguimento qualifica"@it ;
    rdfs:domain pa-recruit:QualificaAccademica ;
    rdfs:range xsd:dateTime ;
    rdfs:comment "La data in cui è stata conseguita la qualifica accademica."@it .

pa-recruit:dataDiIngressoInSessione a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "data di ingresso in sessione"@it ;
