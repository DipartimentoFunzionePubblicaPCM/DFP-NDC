pa-recruit:avvisoDiMobilità a owl:NamedIndividual ;
    rdfs:label "avviso di mobilità"@it ;
    rdfs:comment "Sottoclasse di \"Pubblicazione di reclutamento PA\" che raggruppa le pubblicazioni con categoria di reclutamento caratterizzate dal valore \"avviso di mobilità\", relativa a procedure selettive riservate a soggetti già appartenenti alla Pubblica Amministrazione."@it .

pa-recruit:avvisoOIV a owl:NamedIndividual ;
    rdfs:label "avviso OIV"@it ;
    rdfs:comment "Sottoclasse di Pubblicazione di reclutamento PA che raggruppa le pubblicazioni con categoria di reclutamento valorizzata a \"avviso OIV\"."@it .

pa-recruit:bandoApprendistato a owl:NamedIndividual ;
    rdfs:label "bando apprendistato"@it ;
    rdfs:comment "Sottoclasse di \"Pubblicazione di reclutamento PA\" che raggruppa le pubblicazioni con categoria di reclutamento caratterizzate dal valore \"bando apprendistato\", relativa a procedure di selezione per l'inserimento di apprendisti all'interno della Pubblica Amministrazione."@it .

pa-recruit:concorso a owl:NamedIndividual ;
    rdfs:label "concorso"@it ;
    rdfs:comment "Sottoclasse di \"Pubblicazione di reclutamento PA\" che raggruppa le pubblicazioni con categoria di reclutamento caratterizzate dal valore \"concorso\", relativa a bandi pubblici per l'assunzione di personale nella Pubblica Amministrazione."@it .

pa-recruit:concorsoDFP-FormezPA a owl:NamedIndividual ;
    rdfs:label "concorso DFP - Formez PA"@it ;
    rdfs:comment "Sottoclasse di \"Pubblicazione di reclutamento PA\" che raggruppa le pubblicazioni con categoria di reclutamento caratterizzate dal valore \"Concorso DFP-Formez PA\", relativa a bandi e avvisi gestiti con il supporto tecnico-operativo di Formez PA per conto delle amministrazioni centrali o locali"@it .

pa-recruit:procedureStraordinarie a owl:NamedIndividual ;
    rdfs:label "procedure straordinarie"@it ;
    rdfs:comment "Sottoclasse di Pubblicazione di reclutamento PA che raggruppa le pubblicazioni con categoria di reclutamento valorizzata a \"procedure straordinarie\"."@it .

pa-recruit:sceltaPA-Sede a owl:NamedIndividual ;
    rdfs:label "scelta PA-Sede"@it ;
    rdfs:comment "Sottoclasse di Pubblicazione di reclutamento PA che raggruppa le pubblicazioni con categoria di reclutamento valorizzata a \"scelta PA-Sede\"."@it .

pa-recruit:selezioneProfessionistiEdEsperti a owl:NamedIndividual ;
    rdfs:label "selezione professionisti ed esperti"@it ;
    rdfs:comment "Sottoclasse di \"Pubblicazione di reclutamento PA\" che raggruppa le pubblicazioni con categoria di reclutamento caratterizzate dal valore \"selezione professionisti ed esperti\", relativa alle procedure finalizzate al reclutamento di profili specialistici e professionali."@it .

