        "Dipartimento della Funzione Pubblica della Presidenza del Consiglio dei Ministri"@it ;
    vcard:hasURL <https://github.com/DFPdati> .

<https://w3id.org/italia/public-administration-governance/data/organization/dfpDati> a dcatapit:Organization,
        owl:NamedIndividual,
        vcard:Kind,
        vcard:Organization ;
    rdfs:label "Department of Civil Service - Data"@en,
        "Dipartimento della Funzione Pubblica - Dati"@it ;
    dct:identifier "dfpDati" ;
    foaf:name "Department of Civil Service - Data"@en,
        "Dipartimento della Funzione Pubblica - Dati"@it ;
    vcard:fn "Dipartimento della Funzione Pubblica - Dati" ;
    vcard:hasEmail <mailto:m.rocchia@funzionepubblica.it> ;
    vcard:hasURL <https://github.com/DFPdati> .

<https://w3id.org/italia/public-administration-governance/data/public_sector_recruitment/distribution/PARECRUIT-N-TRIPLES> a adms:SemanticAssetDistribution,
        dcat:Distribution,
        dcatapit:Distribution,
        owl:NamedIndividual ;
    dcat:accessURL <https://github.com/DipartimentoFunzionePubblicaPCM/DFP-NDC/tree/main/assets/ontologies/public_sector_recruitment/latest> ;
    dcat:downloadURL <https://raw.githubusercontent.com/DipartimentoFunzionePubblicaPCM/DFP-NDC/tree/main/assets/ontologies/public_sector_recruitment/latest/public_sector_recruitment.n3> ;
    dct:description "Questa è la distribuzione N-TRIPLES dell'ontologia dei processi di reclutamento nel Portale inPA (Portale unico del reclutamento – in Pubblica Amministrazione) del Ministero per la Pubblica Amministrazione ed in particolare del Dipartimento della Funzione Pubblica."@it,
        "This is the distribution in N-TRIPLES of the inPA Recruitment Portal Ontology describes some of the main concepts of the Recruitment Portal"@en ;
